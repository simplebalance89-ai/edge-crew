# Edge Crew V2 - Environment Variables
# Copy this to .env and fill in your actual API keys
# DO NOT commit .env to git!

# Azure AI / Azure OpenAI inference (for Grok, DeepSeek)
AZURE_AI_KEY=your_ai_inference_key_here
AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com/openai/v1/

# Azure OpenAI (for GPT deployments)
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional: override deployment names if your Azure deployment names differ
AZURE_GROK_DEPLOYMENT=grok-4-1-fast-reasoning
AZURE_GROK_FAST_DEPLOYMENT=grok-4-1-fast-non-reasoning
AZURE_DEEPSEEK_DEPLOYMENT=DeepSeek-V3.2
AZURE_GPT41_DEPLOYMENT=gpt-41
AZURE_GPT41MINI_DEPLOYMENT=gpt-41-mini

# RapidAPI (for Tank01 injuries)
RAPIDAPI_KEY=your_rapidapi_key_here

# SportsGameOdds API
SPORTSGAMEODDS_KEY=your_sgo_key_here

# BallDontLie API (for NBA props)
BALLDONTLIE_API_KEY=your_bdl_key_here

# Optional: Override default directories
# DATA_DIR=./data
# GRADES_DIR=./grades
# PROFILES_DIR=./profiles
